# ─────────────────────────────────────────────────────────────
# SuperStore Analytics System — Azure Credentials Template
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env to source control.
# ─────────────────────────────────────────────────────────────

# ── Azure Subscription ────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=62a5a64b-a36a-4839-89a4-28c6717a2eb0
AZURE_TENANT_ID=d95edf1e-2c7d-42ee-8e84-163229f87133

# ── Service Principal (recommended for production) ────────────
# Create with: az ad sp create-for-rbac --name superstore-analytics
AZURE_CLIENT_ID=your-service-principal-client-id
AZURE_CLIENT_SECRET=your-service-principal-client-secret

# ── Azure Storage Account (Blob + ADLS Gen2) ──────────────────
# Single storage account used for both Blob and ADLS Gen2.
# Requires "Hierarchical namespace" enabled for ADLS.
AZURE_STORAGE_ACCOUNT_NAME=superstoreanalytics
AZURE_STORAGE_ACCOUNT_KEY=your-storage-account-key

# SAS token alternative (optional, for short-lived access)
# AZURE_STORAGE_SAS_TOKEN=?sv=2022-11-02&...

# ── Azure Blob Storage ────────────────────────────────────────
AZURE_BLOB_CONTAINER=superstore-analytics

# ── ADLS Gen2 (Data Lake) ─────────────────────────────────────
AZURE_ADLS_ACCOUNT_NAME=superstoreanalytics
AZURE_ADLS_FILESYSTEM=superstore        # = ADLS container / filesystem name

# ── Azure Databricks ─────────────────────────────────────────
DATABRICKS_HOST=https://<workspace-id>.azuredatabricks.net
DATABRICKS_TOKEN=dapi_your_personal_access_token

# Databricks cluster config
DATABRICKS_CLUSTER_ID=your-cluster-id
DATABRICKS_DBFS_ROOT=/dbfs/superstore

# ── Resource Group (for SDK management operations) ────────────
AZURE_RESOURCE_GROUP=superstore-rg
AZURE_DATABRICKS_WORKSPACE_NAME=superstore-databricks
